# ===========================================
# DAHAB - Configuration (.env)
# ===========================================

# ----------- Database (Neon PostgreSQL) -----------
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ----------- Authentication -----------
# JWT Secret — REQUIRED in production
# Generate with: openssl rand -base64 48
JWT_SECRET="your-secret-key-here-min-32-chars"

# Admin credentials (only used during seed — admin will be forced to reset password on first login)
ADMIN_EMAIL="admin@dahab.ma"
ADMIN_PASSWORD="ChangeMe@FirstLogin2024!"

# ----------- Analytics -----------
# Meta Pixel ID (Facebook/Instagram ads tracking)
NEXT_PUBLIC_META_PIXEL_ID=""

# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=""

# Google Search Console verification
GOOGLE_SITE_VERIFICATION=""

# ----------- WhatsApp -----------
# WhatsApp Business phone number (E.164 format)
WHATSAPP_PHONE="+212XXXXXXXXX"
# Client-side WhatsApp phone (same number, exposed to browser for wa.me links)
NEXT_PUBLIC_WHATSAPP_PHONE="+212XXXXXXXXX"

# ----------- Site -----------
# Site URL (used for SEO, sitemap, OG tags, canonical URLs)
NEXT_PUBLIC_SITE_URL="https://dahab.ma"

# ----------- Email (Resend) -----------
# Resend API Key for transactional emails
RESEND_API_KEY=""
# From email address (must be verified in Resend dashboard)
RESEND_FROM_EMAIL="DAHAB <noreply@dahab.ma>"

# ----------- Cloudflare R2 (Images produits) -----------
# Account ID — visible dans Cloudflare Dashboard → R2 Overview (en bas à droite)
CLOUDFLARE_R2_ACCOUNT_ID=""
# R2 API Token (Create API Token → R2:Edit sur le bucket)
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
# Nom du bucket R2
CLOUDFLARE_R2_BUCKET_NAME="dahab-images"
# URL publique du bucket — soit domaine custom, soit l'URL .r2.dev fournie par CF
# Exemple custom  : https://images.dahab.ma
# Exemple default : https://pub-xxxx.r2.dev
CLOUDFLARE_R2_PUBLIC_URL="https://images.dahab.ma"

# ----------- Serveur -----------
# Port utilisé par le container Docker (HF Spaces impose 7860)
PORT=7860
