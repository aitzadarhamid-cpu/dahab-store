generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  description    String
  price          Float
  compareAtPrice Float?
  images         String      @default("[]") // JSON array of image URLs
  category       String      // BAGUE, COLLIER, BRACELET, BOUCLES_OREILLES
  material       String      // OR_PLAQUE, ARGENT_925, OR_ROSE, ACIER_INOXYDABLE, CRISTAL
  stock          Int         @default(0)
  sizes          String      @default("[]") // JSON array of size strings
  featured       Boolean     @default(false)
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orderItems     OrderItem[]
  reviews        Review[]

  @@index([category, active])
  @@index([active, featured])
  @@index([active, createdAt])
  @@index([price])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  status          String      @default("EN_ATTENTE")
  subtotal        Float
  shipping        Float
  discount        Float       @default(0)
  total           Float
  promoCode       String?
  customerName    String
  customerPhone   String
  customerCity    String
  customerAddress String
  customerNote    String?
  customerEmail   String?
  whatsappSent    Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]

  @@index([status])
  @@index([createdAt])
  @@index([customerPhone])
}

model OrderItem {
  id           String   @id @default(cuid())
  quantity     Int
  priceAtOrder Float
  selectedSize String?
  productName  String
  productImage String
  orderId      String
  productId    String?
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Admin {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  mustResetPassword Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PromoCode {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String    // PERCENTAGE or FIXED
  value     Float     // percentage (e.g. 10) or fixed amount (e.g. 25)
  minOrder  Float     @default(0)
  maxUses   Int       @default(0) // 0 = unlimited
  usedCount Int       @default(0)
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model Review {
  id           String   @id @default(cuid())
  productId    String
  customerName String
  rating       Int      // 1-5
  comment      String
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now())
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, approved])
}

model Newsletter {
  id           String   @id @default(cuid())
  email        String   @unique
  firstName    String   @default("")
  subscribedAt DateTime @default(now())
  active       Boolean  @default(true)
}

model CustomerLoyalty {
  id            String   @id @default(cuid())
  phone         String   @unique
  name          String   @default("")
  totalOrders   Int      @default(0)
  totalSpent    Float    @default(0)
  loyaltyPoints Int      @default(0)
  tier          String   @default("BRONZE") // BRONZE, SILVER, GOLD, DIAMOND
  createdAt     DateTime @default(now())
}
