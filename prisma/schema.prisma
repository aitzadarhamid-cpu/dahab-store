generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  description    String
  price          Float
  compareAtPrice Float?
  images         String      @default("[]") // JSON array of image URLs
  category       String      // BAGUE, COLLIER, BRACELET, BOUCLES_OREILLES
  material       String      // OR_PLAQUE, ARGENT_925, OR_ROSE, ACIER_INOXYDABLE, CRISTAL
  stock          Int         @default(0)
  sizes          String      @default("[]") // JSON array of size strings
  featured       Boolean     @default(false)
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orderItems     OrderItem[]
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  status          String      @default("EN_ATTENTE")
  subtotal        Float
  shipping        Float
  total           Float
  customerName    String
  customerPhone   String
  customerCity    String
  customerAddress String
  customerNote    String?
  whatsappSent    Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
}

model OrderItem {
  id           String   @id @default(cuid())
  quantity     Int
  priceAtOrder Float
  selectedSize String?
  productName  String
  productImage String
  orderId      String
  productId    String?
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
